{
  "manifest_version": 3,
  "name": "ContextBot",
  "version": "0.2.0",
  "description": "Get an instant intelligence brief on any article you read — source bias, key claims, missing context, and other perspectives.",
  "permissions": [
    "activeTab",
    "sidePanel",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"]
    }
  ],
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_title": "Open ContextBot"
  }
}
